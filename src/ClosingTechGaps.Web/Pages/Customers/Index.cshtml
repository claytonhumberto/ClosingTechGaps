@page
@model ClosingTechGaps.Web.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Customers";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Customers</h2>
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted">
                Total: <strong>@Model.Customers.TotalCount</strong> customers
            </span>
            <form method="get" class="d-flex align-items-center gap-2 ms-3">
                <input type="hidden" name="currentPage" value="1" />
                <label class="mb-0 text-muted">Per page:</label>
                <select name="pageSize" class="form-select form-select-sm" style="width:80px" onchange="this.form.submit()">
                    @foreach (var size in new[] { 10, 20, 50, 100 })
                    {
                        if (size == Model.PageSize)
                        {
                            <option value="@size" selected>@size</option>
                        }
                        else
                        {
                            <option value="@size">@size</option>
                        }
                    }
                </select>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Birthday</th>
                            <th>City / State</th>
                            <th>Address</th>
                            <th>Email</th>
                            <th>Phone</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model.Customers.Items)
                        {
                            <tr>
                                <td>@customer.Name</td>
                                <td>@customer.BirthdayDate.ToString("MM/dd/yyyy")</td>
                                <td>@customer.Address.City / @customer.Address.State</td>
                                <td>@customer.Address.Street, @customer.Address.ZipCode</td>
                                <td>@customer.ContactInfo.Email</td>
                                <td>@customer.ContactInfo.Phone</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @{
        var totalPages = Model.Customers.TotalPages;
        var currentPage = Model.Customers.Page;
        var pageSize = Model.Customers.PageSize;

        int startPage = Math.Max(1, currentPage - 2);
        int endPage = Math.Min(totalPages, currentPage + 2);
    }

    <nav aria-label="Pagination" class="mt-3">
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @{
                    var firstItem = Model.Customers.TotalCount == 0 ? 0 : (currentPage - 1) * pageSize + 1;
                    var lastItem = Math.Min(currentPage * pageSize, Model.Customers.TotalCount);
                }
                Showing @firstItem to @lastItem of @Model.Customers.TotalCount records
            </small>
            <ul class="pagination mb-0">
                <li class="page-item @(!Model.Customers.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-page="./Index"
                       asp-route-currentPage="1"
                       asp-route-pageSize="@pageSize">&laquo;</a>
                </li>
                <li class="page-item @(!Model.Customers.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" asp-page="./Index"
                       asp-route-currentPage="@(currentPage - 1)"
                       asp-route-pageSize="@pageSize">&lsaquo;</a>
                </li>

                @for (int p = startPage; p <= endPage; p++)
                {
                    <li class="page-item @(p == currentPage ? "active" : "")">
                        <a class="page-link" asp-page="./Index"
                           asp-route-currentPage="@p"
                           asp-route-pageSize="@pageSize">@p</a>
                    </li>
                }

                <li class="page-item @(!Model.Customers.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-page="./Index"
                       asp-route-currentPage="@(currentPage + 1)"
                       asp-route-pageSize="@pageSize">&rsaquo;</a>
                </li>
                <li class="page-item @(!Model.Customers.HasNextPage ? "disabled" : "")">
                    <a class="page-link" asp-page="./Index"
                       asp-route-currentPage="@totalPages"
                       asp-route-pageSize="@pageSize">&raquo;</a>
                </li>
            </ul>
        </div>
    </nav>
</div>
